<Window x:Class="ImageCompression.Wpf.ImageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Icon="Resources/app_icon.ico"
        Height="740"
        Width="620"
        MinHeight="640"
        MinWidth="560"
        WindowStartupLocation="CenterOwner">
    <!--
        설정 창 레이아웃
        - 상단: 제목
        - 중앙: 스크롤 가능한 옵션 그룹(품질/포맷/정책/언어)
        - 하단: 취소/적용 액션 버튼
    -->
    <DockPanel Margin="16">
        <!-- 헤더 영역 -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,10">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource Settings.Header}" />
            </StackPanel>
        </Border>

        <!-- 하단 액션 버튼 -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="90" Height="30" Margin="0,0,8,0" Content="{DynamicResource Settings.Cancel}" IsCancel="True" Style="{StaticResource GhostButtonStyle}" />
            <Button Width="90" Height="30" Content="{DynamicResource Settings.Apply}" IsDefault="True" Click="ApplyButton_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 품질/속도 균형 관련 옵션 -->
                <GroupBox Header="{DynamicResource Settings.Group.QualitySpeed}" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.AutoQualityLevel.Label}" />
                        <ComboBox x:Name="AutoQualityLevelComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="8,4"
                                  ToolTip="{DynamicResource Settings.AutoQualityLevel.Tooltip}"
                                  SelectionChanged="AnyUxStateControl_Changed">
                            <ComboBoxItem Tag="Off" Content="{DynamicResource Settings.AutoQualityLevel.Off}" />
                            <ComboBoxItem Tag="High" Content="{DynamicResource Settings.AutoQualityLevel.High}" />
                            <ComboBoxItem Tag="Balanced" Content="{DynamicResource Settings.AutoQualityLevel.Balanced}" />
                            <ComboBoxItem Tag="Aggressive" Content="{DynamicResource Settings.AutoQualityLevel.Aggressive}" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.QualityMetric.Label}" />
                        <ComboBox x:Name="QualityMetricComboBox" Grid.Row="1" Grid.Column="1" Margin="8,4"
                                  ToolTip="{DynamicResource Settings.QualityMetric.Tooltip}">
                            <ComboBoxItem Tag="Psnr" Content="PSNR" />
                            <ComboBoxItem Tag="Ssim" Content="SSIM" />
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.JpegQuality.Label}" />
                        <TextBox x:Name="JpegQualityTextBox" Grid.Row="2" Grid.Column="1" Margin="8,4"
                                 ToolTip="{DynamicResource Settings.JpegQuality.Tooltip}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.ParallelWorkers.Label}" />
                        <ComboBox x:Name="ParallelWorkersComboBox" Grid.Row="3" Grid.Column="1" Margin="8,4"
                                  ToolTip="{DynamicResource Settings.ParallelWorkers.Tooltip}">
                            <ComboBoxItem Tag="0" Content="{DynamicResource Settings.ParallelWorkers.Auto}" />
                            <ComboBoxItem Tag="2" Content="{DynamicResource Settings.ParallelWorkers.W2}" />
                            <ComboBoxItem Tag="4" Content="{DynamicResource Settings.ParallelWorkers.W4}" />
                            <ComboBoxItem Tag="8" Content="{DynamicResource Settings.ParallelWorkers.W8}" />
                            <ComboBoxItem Tag="12" Content="{DynamicResource Settings.ParallelWorkers.W12}" />
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- 포맷/인코딩 관련 옵션 -->
                <GroupBox Header="{DynamicResource Settings.Group.Format}" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="ConvertToJpegCheckBox"
                                  Content="{DynamicResource Settings.ConvertAllToJpeg.Content}"
                                  Margin="0,0,0,6"
                                  ToolTip="{DynamicResource Settings.ConvertAllToJpeg.Tooltip}"
                                  Checked="AnyUxStateControl_Changed"
                                  Unchecked="AnyUxStateControl_Changed" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.WebpQuality.Label}" />
                            <TextBox x:Name="WebpQualityTextBox" Grid.Row="0" Grid.Column="1" Margin="8,4"
                                     ToolTip="{DynamicResource Settings.WebpQuality.Tooltip}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.PngCompressionLevel.Label}" />
                            <TextBox x:Name="PngLevelTextBox" Grid.Row="1" Grid.Column="1" Margin="8,4"
                                     ToolTip="{DynamicResource Settings.PngCompressionLevel.Tooltip}" />
                        </Grid>

                        <Separator Margin="0,8,0,8" />

                        <CheckBox x:Name="EnableAutoFormatSelectionCheckBox"
                                  Content="{DynamicResource Settings.EnableAutoFormatSelection.Content}"
                                  Margin="0,0,0,6"
                                  ToolTip="{DynamicResource Settings.EnableAutoFormatSelection.Tooltip}"
                                  Checked="AnyUxStateControl_Changed"
                                  Unchecked="AnyUxStateControl_Changed" />
                        <CheckBox x:Name="PreferWebpForPhotosCheckBox" Margin="20,0,0,4" Content="{DynamicResource Settings.PreferWebpForPhotos.Content}"
                                  ToolTip="{DynamicResource Settings.PreferWebpForPhotos.Tooltip}" />
                        <CheckBox x:Name="UseLosslessWebpForAlphaCheckBox" Margin="20,0,0,0" Content="{DynamicResource Settings.UseLosslessWebpForAlpha.Content}"
                                  ToolTip="{DynamicResource Settings.UseLosslessWebpForAlpha.Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- 처리 정책(리사이즈/메타데이터/JPEG 정책) -->
                <GroupBox Header="{DynamicResource Settings.Group.Policy}">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="EnableResizeCheckBox"
                                  Content="{DynamicResource Settings.EnableResize.Content}"
                                  Margin="0,0,0,6"
                                  ToolTip="{DynamicResource Settings.EnableResize.Tooltip}"
                                  Checked="AnyUxStateControl_Changed"
                                  Unchecked="AnyUxStateControl_Changed" />
                        <Grid Margin="20,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.MaxWidth.Label}" />
                            <TextBox x:Name="MaxWidthTextBox" Grid.Column="1" Margin="8,0,0,0"
                                     ToolTip="{DynamicResource Settings.MaxWidth.Tooltip}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{DynamicResource Settings.MaxHeight.Label}" />
                            <TextBox x:Name="MaxHeightTextBox" Grid.Column="4" Margin="8,0,0,0"
                                     ToolTip="{DynamicResource Settings.MaxHeight.Tooltip}" />
                        </Grid>
                        <CheckBox x:Name="ResizeOnlyWhenOversizedCheckBox" Margin="20,0,0,8" Content="{DynamicResource Settings.ResizeOnlyWhenOversized.Content}"
                                  ToolTip="{DynamicResource Settings.ResizeOnlyWhenOversized.Tooltip}" />

                        <CheckBox x:Name="StripMetadataCheckBox" Margin="0,0,0,4" Content="{DynamicResource Settings.StripMetadata.Content}"
                                  ToolTip="{DynamicResource Settings.StripMetadata.Tooltip}" />
                        <CheckBox x:Name="UseJpeg420SubsamplingCheckBox" Margin="0,0,0,4" Content="{DynamicResource Settings.UseJpeg420Subsampling.Content}"
                                  ToolTip="{DynamicResource Settings.UseJpeg420Subsampling.Tooltip}" />
                        <CheckBox x:Name="UseProgressiveJpegCheckBox" Margin="0,0,0,4" Content="{DynamicResource Settings.UseProgressiveJpeg.Content}"
                                  ToolTip="{DynamicResource Settings.UseProgressiveJpeg.Tooltip}" />
                        <CheckBox x:Name="KeepOriginalWhenLargerCheckBox" Margin="0,4,0,0" Content="{DynamicResource Settings.KeepOriginalWhenLarger.Content}"
                                  ToolTip="{DynamicResource Settings.KeepOriginalWhenLarger.Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- UI 언어 설정 -->
                <GroupBox Header="{DynamicResource Settings.Language}" Margin="0,10,0,0">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings.Language}" />
                        <ComboBox x:Name="LanguageComboBox" Grid.Column="1" Margin="8,4">
                            <ComboBoxItem Tag="ko" Content="{DynamicResource Settings.Language.Korean}" />
                            <ComboBoxItem Tag="en" Content="{DynamicResource Settings.Language.English}" />
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <TextBlock x:Name="BuildVersionTextBlock"
                           Margin="4,10,4,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource SubtleTextBrush}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
