<Window x:Class="ImageCompression.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource App.Title.Main}"
        Icon="Resources/app_icon.ico"
        Height="760"
        Width="1280"
        MinWidth="980"
        MinHeight="680"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop">
    <!--
        메인 레이아웃: 좌측(입력/설정/실행/목록/로그), 우측(압축 결과 미리보기)
        리사이즈 시 우측 미리보기에 더 넓은 비중을 주기 위해 1.25*:1.75* 비율 사용
    -->
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="1.75*" />
        </Grid.ColumnDefinitions>

        <!-- 좌측 작업 패널: 입력부터 실행/로그까지 전체 워크플로우 -->
        <Border Grid.Column="0" Margin="0,0,10,0" Padding="12" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.4*" MinHeight="200" />
                <RowDefinition Height="1.3*" MinHeight="60" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 입력 영역: 파일/폴더 선택 + 최근 입력 재사용 -->
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Top" Text="{DynamicResource Main.Input}" />
            <TextBox x:Name="InputZipTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Margin="8,2"
                     Height="30"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     ToolTip="ZIP/이미지/폴더를 창 어디든 드래그하세요." />
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,2" Orientation="Horizontal">
                <Button x:Name="BrowseInputButton"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="88"
                        Height="30"
                        Content="{DynamicResource Main.Browse}"
                        Click="BrowseInputButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="InputBrowseContextMenu">
                            <MenuItem Header="{DynamicResource Main.Browse.File}" Click="BrowseInputFileMenuItem_Click" />
                            <MenuItem Header="{DynamicResource Main.Browse.Folder}" Click="BrowseInputFolderMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="RecentInputsButton"
                        Margin="6,0,0,0"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="60"
                        Height="30"
                        Content="{DynamicResource Main.Recent}"
                        Click="RecentInputsButton_Click" />
            </StackPanel>

            <!-- 저장 옵션: 출력 형식/접미사/충돌 처리/결과 폴더 열기 -->
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Top" Text="{DynamicResource Main.SaveOption}" />
            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="OutputModeComboBox"
                              Grid.Column="0"
                              Height="30"
                              SelectionChanged="OutputModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource Main.Save.Zip}" Tag="zip" IsSelected="True" />
                        <ComboBoxItem Content="{DynamicResource Main.Save.Folder}" Tag="folder" />
                    </ComboBox>

                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{DynamicResource Main.Suffix}" />
                    <TextBox x:Name="OutputSuffixTextBox"
                             Grid.Column="4"
                             Height="30"
                             VerticalContentAlignment="Center"
                             TextChanged="OutputSuffixTextBox_TextChanged"
                             ToolTip="예: _output (비우면 접미사 없음)" />
                </Grid>
                <TextBlock x:Name="OutputPathPreviewTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" />
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Main.ConflictMode}" />
                    <ComboBox x:Name="OutputConflictModeComboBox"
                              Grid.Column="1"
                              Height="28"
                              SelectionChanged="OutputConflictModeComboBox_SelectionChanged">
                        <ComboBoxItem Tag="autorename" Content="{DynamicResource Main.Conflict.AutoRename}" />
                        <ComboBoxItem Tag="overwrite" Content="{DynamicResource Main.Conflict.Overwrite}" />
                        <ComboBoxItem Tag="skip" Content="{DynamicResource Main.Conflict.Skip}" />
                    </ComboBox>
                    <Button x:Name="OpenOutputButton"
                            Grid.Column="3"
                            Height="28"
                            MinWidth="120"
                            IsEnabled="False"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="{DynamicResource Main.OpenOutput}"
                            Click="OpenOutputButton_Click" />
                </Grid>
            </StackPanel>

            <!-- 빠른 이미지 설정 + 프리셋 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Top" Text="{DynamicResource Main.ImageSettings}" />
            <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Main.QuickSettings}" FontWeight="SemiBold" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Main.Preset}" />
                        <ComboBox x:Name="PresetComboBox" Grid.Column="1" Margin="0,0,8,0" Height="28" IsEditable="True" IsReadOnly="False" />
                        <Button x:Name="SavePresetButton" Grid.Column="2" Margin="0,0,6,0" MinWidth="64" Height="28" Content="{DynamicResource Main.PresetSave}" Click="SavePresetButton_Click" />
                        <Button x:Name="ApplyPresetButton" Grid.Column="3" MinWidth="64" Height="28" Content="{DynamicResource Main.PresetApply}" Click="ApplyPresetButton_Click" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Main.JpegQuality}" />
                        <Slider x:Name="MainJpegQualitySlider"
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                Minimum="1"
                                Maximum="100"
                                TickFrequency="5"
                                ValueChanged="MainJpegQualitySlider_ValueChanged" />
                        <TextBlock x:Name="MainJpegQualityValueTextBlock"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="MainEnableResizeCheckBox"
                                  Grid.Column="0"
                                  Content="{DynamicResource Main.Resize}"
                                  VerticalAlignment="Center"
                                  Checked="MainResizeOptionChanged"
                                  Unchecked="MainResizeOptionChanged" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text=" W  " />
                        <TextBox x:Name="MainMaxWidthTextBox"
                                 Grid.Column="3"
                                 MinWidth="70"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 TextChanged="MainResizeTextBox_TextChanged" />
                        <TextBlock Grid.Column="5" VerticalAlignment="Center" Text=" H  " />
                        <TextBox x:Name="MainMaxHeightTextBox"
                                 Grid.Column="6"
                                 MinWidth="70"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 TextChanged="MainResizeTextBox_TextChanged" />
                    </Grid>

                    <Button Width="120" Margin="0,8,0,0" Content="{DynamicResource Main.OpenSettings}" HorizontalAlignment="Left" Click="OpenSettingsButton_Click" Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
            </Border>

            <!-- 실행 영역: 실행/취소/진행바 + 샘플 기반 예상 용량 -->
            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RunButton"
                            Grid.Column="0"
                            MinWidth="180"
                            Height="32"
                            IsEnabled="False"
                            Content="{DynamicResource Main.StartCompress}"
                            Click="RunButton_Click" />
                    <Button x:Name="CancelButton"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            MinWidth="90"
                            Height="32"
                            Content="{DynamicResource Main.Cancel}"
                            IsEnabled="False"
                            Click="CancelButton_Click"
                            Style="{StaticResource GhostButtonStyle}" />
                    <Grid Grid.Column="2" Margin="12,0,0,0" MinWidth="50" VerticalAlignment="Center">
                        <ProgressBar x:Name="CompressProgressBar"
                                     Height="20"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="0" />
                        <TextBlock x:Name="CompressProgressTextBlock"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="0 / 0" />
                    </Grid>
                </Grid>
                <TextBlock x:Name="EstimateSummaryTextBlock"
                           Grid.Row="1"
                           Margin="0,8,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>

            <!-- 대상 목록: 전체 이미지 + 실패 항목 필터 -->
            <GroupBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Header="{DynamicResource Main.TargetList}" Margin="0,8,0,0">
                <DockPanel Margin="8">
                    <TextBlock x:Name="InputFilesCountTextBlock" DockPanel.Dock="Top" Margin="0,0,0,8" />
                    <CheckBox x:Name="ShowFailedOnlyCheckBox"
                              DockPanel.Dock="Top"
                              Margin="0,0,0,8"
                              Content="{DynamicResource Main.ShowFailedOnly}"
                              Checked="ShowFailedOnlyCheckBox_Changed"
                              Unchecked="ShowFailedOnlyCheckBox_Changed" />
                    <DataGrid x:Name="InputImagesDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="InputImagesDataGrid_SelectionChanged"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Main.List.File}" Binding="{Binding DisplayPath}" Width="*" />
                            <DataGridTextColumn Header="{DynamicResource Main.List.Resolution}" Binding="{Binding DimensionsText}" Width="110" />
                            <DataGridTextColumn Header="{DynamicResource Main.List.Size}" Binding="{Binding SizeText}" Width="100" />
                            <DataGridTextColumn Header="{DynamicResource Main.List.Source}" Binding="{Binding SourceType}" Width="95" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <!-- 로그 영역: 타임스탬프 + 심각도별 색상 강조 -->
            <RichTextBox x:Name="LogTextBox"
                         Grid.Row="5"
                         Grid.Column="0"
                         Grid.ColumnSpan="3"
                         Style="{x:Null}"
                         Height="Auto"
                         MinHeight="100"
                         Margin="0,8,0,0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="#0F172A"
                         Foreground="#DCE6FF"
                         BorderBrush="#233252"
                         IsReadOnly="True"
                         IsDocumentEnabled="False" />
        </Grid>
        </Border>

        <!-- 우측 미리보기 패널: 선택 이미지의 압축 결과를 인라인 표시 -->
        <GroupBox Grid.Column="1" Margin="10,0,0,0" Header="{DynamicResource Main.Preview}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <CheckBox x:Name="PreviewCompareCheckBox"
                          Content="{DynamicResource Main.PreviewCompare}"
                          Margin="0,0,0,8"
                          Checked="PreviewCompareCheckBox_Changed"
                          Unchecked="PreviewCompareCheckBox_Changed" />

                <Border Grid.Row="1" Margin="0,0,0,12" Padding="10" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                    <TextBlock x:Name="InlinePreviewSummaryTextBlock"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="20" />
                </Border>
                <Border Grid.Row="2" Background="#0B1220" Padding="12" CornerRadius="6">
                    <Image x:Name="InlineCompressedImage" Stretch="Uniform" />
                </Border>
            </Grid>
        </GroupBox>

        <!-- 입력 스캔 중 전체 화면 오버레이 -->
        <Border x:Name="InputLoadingOverlay"
                Grid.ColumnSpan="2"
                Background="#90FFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="18"
                    Background="White"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Width="260">
                    <TextBlock x:Name="InputLoadingTextBlock"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Text="{DynamicResource Ui.InputLoading}" />
                    <ProgressBar Margin="0,12,0,0"
                                 Height="18"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
