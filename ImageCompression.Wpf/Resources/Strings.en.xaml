    <sys:String x:Key="Settings.Language">Language</sys:String>
    <sys:String x:Key="Settings.Language.Korean">Korean</sys:String>
    <sys:String x:Key="Settings.Language.English">English</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.Label">Auto Quality Search</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.Tooltip">Automatically searches quality to reduce size. If off, fixed JPEG/WebP quality values are used for faster processing.</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.Off">Off (use fixed quality)</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.High">High quality (SSIM≈0.985 / PSNR≈40)</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.Balanced">Balanced (SSIM≈0.97 / PSNR≈35)</sys:String>
    <sys:String x:Key="Settings.AutoQualityLevel.Aggressive">High compression (SSIM≈0.95 / PSNR≈31)</sys:String>
    <sys:String x:Key="Settings.QualityMetric.Label">Quality Metric</sys:String>
    <sys:String x:Key="Settings.QualityMetric.Tooltip">Metric used for auto quality search. SSIM is closer to perceived quality, PSNR is simpler/faster.</sys:String>
    <sys:String x:Key="Settings.JpegQuality.Label">JPEG Quality (1-100)</sys:String>
    <sys:String x:Key="Settings.JpegQuality.Tooltip">Fixed JPEG quality value. Higher values improve quality but increase file size.</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.Label">Parallel Workers</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.Tooltip">Number of concurrent compression tasks. Higher values can be faster but use more CPU.</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.Auto">Auto (based on CPU)</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.W2">2 workers</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.W4">4 workers</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.W8">8 workers</sys:String>
    <sys:String x:Key="Settings.ParallelWorkers.W12">12 workers</sys:String>
    <sys:String x:Key="Settings.ConvertAllToJpeg.Content">Convert all images to JPEG</sys:String>
    <sys:String x:Key="Settings.ConvertAllToJpeg.Tooltip">Converts PNG/WebP etc. to JPEG. This often reduces photos, but transparency may be lost.</sys:String>
    <sys:String x:Key="Settings.WebpQuality.Label">WebP Quality (1-100)</sys:String>
    <sys:String x:Key="Settings.WebpQuality.Tooltip">WebP lossy quality value. Higher values improve quality but increase file size.</sys:String>
    <sys:String x:Key="Settings.PngCompressionLevel.Label">PNG Compression Level (1-9)</sys:String>
    <sys:String x:Key="Settings.PngCompressionLevel.Tooltip">PNG lossless compression strength. Higher levels may be slower but can reduce size.</sys:String>
    <sys:String x:Key="Settings.EnableAutoFormatSelection.Content">Auto format selection (photo/graphic split)</sys:String>
    <sys:String x:Key="Settings.EnableAutoFormatSelection.Tooltip">Automatically chooses JPEG/WebP/PNG by image characteristics. Better quality retention, but may take longer.</sys:String>
    <sys:String x:Key="Settings.PreferWebpForPhotos.Content">Prefer WebP for photos</sys:String>
    <sys:String x:Key="Settings.PreferWebpForPhotos.Tooltip">Stores photo-like images in WebP first. Usually smaller than JPEG, but encoding can be slower.</sys:String>
    <sys:String x:Key="Settings.UseLosslessWebpForAlpha.Content">Prefer lossless WebP for transparent images</sys:String>
    <sys:String x:Key="Settings.UseLosslessWebpForAlpha.Tooltip">Uses lossless WebP for images with alpha (transparency). Often a good PNG alternative.</sys:String>
    <sys:String x:Key="Settings.EnableResize.Content">Enable resize</sys:String>
    <sys:String x:Key="Settings.EnableResize.Tooltip">Resizes images to reduce file size. Effective when many images are large.</sys:String>
    <sys:String x:Key="Settings.MaxWidth.Label">Max Width</sys:String>
    <sys:String x:Key="Settings.MaxWidth.Tooltip">Maximum width in pixels when resizing. Aspect ratio is preserved.</sys:String>
    <sys:String x:Key="Settings.MaxHeight.Label">Max Height</sys:String>
    <sys:String x:Key="Settings.MaxHeight.Tooltip">Maximum height in pixels when resizing. Aspect ratio is preserved.</sys:String>
    <sys:String x:Key="Settings.ResizeOnlyWhenOversized.Content">Resize only when oversized</sys:String>
    <sys:String x:Key="Settings.ResizeOnlyWhenOversized.Tooltip">Skips resizing when the image is already small. Reduces quality loss and improves speed.</sys:String>
    <sys:String x:Key="Settings.StripMetadata.Content">Strip metadata (EXIF/ICC/IPTC/XMP)</sys:String>
    <sys:String x:Key="Settings.StripMetadata.Tooltip">Removes extra metadata such as camera/location info to reduce size.</sys:String>
    <sys:String x:Key="Settings.UseJpeg420Subsampling.Content">Use JPEG chroma subsampling 4:2:0</sys:String>
    <sys:String x:Key="Settings.UseJpeg420Subsampling.Tooltip">Compresses color data more aggressively to reduce JPEG size, usually with minor visual impact for photos.</sys:String>
    <sys:String x:Key="Settings.UseProgressiveJpeg.Content">Use progressive JPEG</sys:String>
    <sys:String x:Key="Settings.UseProgressiveJpeg.Tooltip">Creates JPEGs that appear blurry first and progressively sharpen in supported viewers.</sys:String>
    <sys:String x:Key="Settings.KeepOriginalWhenLarger.Content">Keep original when compressed is larger</sys:String>
    <sys:String x:Key="Settings.KeepOriginalWhenLarger.Tooltip">If compressed output is larger than source, keep the original automatically.</sys:String>

