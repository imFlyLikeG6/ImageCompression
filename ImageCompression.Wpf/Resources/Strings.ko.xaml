    <sys:String x:Key="Settings.Cancel">취소</sys:String>
    <sys:String x:Key="Settings.Apply">적용</sys:String>
    <sys:String x:Key="Settings.Group.QualitySpeed">품질 / 속도</sys:String>
    <sys:String x:Key="Settings.Group.Format">포맷 / 인코딩</sys:String>
